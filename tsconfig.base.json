{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@opencode-agent-os/config": [
        "packages/config/src/index.ts"
      ],
      "@opencode-agent-os/automation": [
        "packages/automation/src/index.ts"
      ],
      "@opencode-agent-os/evaluators": [
        "packages/evaluators/src/index.ts"
      ],
      "@opencode-agent-os/gateway-core": [
        "packages/gateway-core/src/index.ts"
      ],
      "@opencode-agent-os/provider": [
        "packages/provider/src/index.ts"
      ],
      "@opencode-agent-os/runtime-process": [
        "packages/runtime-process/src/index.ts"
      ],
      "@opencode-agent-os/runtime-runner": [
        "packages/runtime-runner/src/index.ts"
      ],
      "@opencode-agent-os/runtime-session": [
        "packages/runtime-session/src/index.ts"
      ],
      "@opencode-agent-os/runtime-supervisor": [
        "packages/runtime-supervisor/src/index.ts"
      ],
      "@opencode-agent-os/runtime-task": [
        "packages/runtime-task/src/index.ts"
      ],
      "@opencode-agent-os/runtime-thread": [
        "packages/runtime-thread/src/index.ts"
      ],
      "@opencode-agent-os/shared": [
        "packages/shared/src/index.ts"
      ],
      "@opencode-agent-os/storage": [
        "packages/storage/src/index.ts"
      ],
      "@opencode-agent-os/tools": [
        "packages/tools/src/index.ts"
      ]
    }
  }
}
